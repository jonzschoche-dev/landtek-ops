# Secrets — NEVER commit
.env
.env.*
*.pem
*.key
*-credentials.json
*-service-account*.json
landtek-compute-sa.json
google-creds*.json
client_secret_*.json
*sa.json

# OAuth client configs and state — contain client_secret / code_verifier
*oauth_client*.json
*oauth_state*.json

# Document/case content (binary, privileged) — keep in Drive, not git
*.pdf
*.docx
*.doc
inbox/
reports/
case_files/
intake_out/
memo_out/
pass1_out/
pass2_out/
per_page_work/
heightened_ocr/
n8n_code_nodes/n8n_data_export*

# Drive inventory snapshot (large, regenerable)
drive_inventory.json

# User uploads (private + large)
uploads/

# Backups (handled by rclone → Drive nightly)
backups/
*.sql.gz
*.dump

# Python crud
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Logs
logs/
*.log

# Editor / OS
.DS_Store
.vscode/
.idea/

# n8n local data (mounted volume — not source)
n8n_data/

# Workflow snapshots — INCLUDED for full audit history (each ~70-90 KB, 1.2 MB total)
# Uncomment to exclude:
# snapshots/*.json
staging/.env

# Daemon-written runtime state (churns constantly, never commit)
system_state.json
drafts/daily_digest_*.md

# SYSTEM_CONSTITUTION.md — auto-generated FACTS layer, regenerated daily on the VPS by
# constitution_generator.py (rides landtek-cross-client.timer). Tracking it would dirty the
# VPS tree nightly and break the multi-agent pull protocol (cf. notifications/pending.txt).
# Read it on the VPS; regenerate with: python3 scripts/constitution_generator.py --write
SYSTEM_CONSTITUTION.md
SYSTEM_BRIEF.md

# Sweep-loop heartbeat (daemon-written, changes every cycle)
notifications/pending.txt
notifications/blocked.txt

# Per-machine Claude Code config (permissions allowlist, machine-specific paths)
.claude/settings.local.json

# Pre-merge snapshots from the multi-agent git routine (see feedback_multi_agent_git_routine.md)
*.mac-backup-*
*.vps-backup-*

# Generated derivative outputs — regenerable from producers
drafts/
1891_output/
ombudsman_output/
playbooks/ombudsman_hunter_*.json

# Case evidence artifacts — canonical in Google Drive (Drive-canonical storage
# policy), not hoarded as binaries in git. Kept local on the machine that dropped
# them; back up to Drive rather than committing.
evidence/

# OCR-attack: Drive folder symlink (designer convenience, never committed)
drive_local
ocr_pending_write/

# local data store (gmail cache + packet outputs) — large, regenerable, never commit
corpus_store/
# editor/backup artifacts
*.bak_matrix
