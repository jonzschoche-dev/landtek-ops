[Unit]
Description=LandTek cross-client sentinel + constitution (collapse exact-dup re-spawns + role-aware conflation + mis-file + entity-canon drift, then regenerate SYSTEM_CONSTITUTION.md). $0, no LLM.
After=network-online.target docker.service

[Service]
Type=oneshot
EnvironmentFile=-/root/landtek/.env
WorkingDirectory=/root/landtek
ExecStart=/usr/bin/python3 /root/landtek/scripts/entity_resolve.py --apply-auto
ExecStart=/usr/bin/python3 /root/landtek/scripts/cross_client_sentinel.py --apply-canon
ExecStart=/usr/bin/python3 /root/landtek/scripts/cross_client_sentinel.py --report --log
ExecStart=/usr/bin/python3 /root/landtek/scripts/constitution_generator.py --write
StandardOutput=append:/var/log/landtek_cross_client.log
StandardError=append:/var/log/landtek_cross_client.log
