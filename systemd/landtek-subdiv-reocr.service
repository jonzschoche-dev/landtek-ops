[Unit]
Description=LandTek — retry frontier re-OCR of Psd-221861 flagged lots (2-G/2-M/2-X) when Gemini quota is back
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/landtek
EnvironmentFile=/root/landtek/.env
ExecStart=/usr/bin/python3 /root/landtek/scripts/subdivision_reocr_retry.py
# degrades gracefully on 429/5xx (exits 0); only maps a lot that passes the closure+area gate
TimeoutStartSec=600
