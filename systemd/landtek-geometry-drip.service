[Unit]
Description=LandTek geometry drip — geometry_pipeline.py --backend local: re-OCR the next few geometry_priority docs with the OWNED local vision model (Mac Ollama qwen2.5vl over Tailscale, $0 no tokens) to fix garbled technical descriptions, then strip_plot_info parses the clean metes-and-bounds into `parcels` shapes. Creditless + offline-sovereign; stops CLEANLY if the local tier is unreachable (exit 0) and resumes next run. Never fabricates geometry.
After=network-online.target docker.service

[Service]
Type=oneshot
EnvironmentFile=-/root/landtek/.env
WorkingDirectory=/root/landtek
ExecStart=/usr/bin/python3 /root/landtek/scripts/geometry_pipeline.py --max 6 --backend local
StandardOutput=append:/var/log/landtek_geometry_drip.log
StandardError=append:/var/log/landtek_geometry_drip.log
